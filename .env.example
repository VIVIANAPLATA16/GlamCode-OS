# Copia a .env y rellena (no subas secretos a git).
# SECRET_KEY=genera-un-valor-largo-aleatorio
# FLASK_ENV=production

# Base URL pública (QR, enlaces)
# BASE_URL=https://glamcode-os.onrender.com

# TiDB / MySQL
# DB_HOST=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# DB_PORT=4000

# Opcional: URI completa para SQLAlchemy
# DATABASE_URL=mysql+mysqlconnector://user:pass@host:4000/dbname

# Reservas públicas: ID del usuario (salón) dueño de servicios/citas
# PUBLIC_BOOKING_USUARIO_ID=1

# Dashboard métricas
# CAPACIDAD_DIARIA=20

# Twilio WhatsApp (sandbox o número aprobado)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Recordatorios: solo en un worker/dyno (ej. 1)
# ENABLE_SCHEDULER=true
